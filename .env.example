# Supabase
# Get these from your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Keep secret — server-side only

# Toss Payments
# Get test keys from https://developers.tosspayments.com → Dashboard > Dev > API Keys
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_your-client-key-here
TOSS_SECRET_KEY=test_sk_your-secret-key-here
TOSS_WEBHOOK_SECRET=your-webhook-secret-here   # Set in Toss dashboard webhook settings

# Site URL (used for OAuth redirect)
# Local: http://localhost:3000 | Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
